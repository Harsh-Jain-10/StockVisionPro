OPENAI_API_KEY=your_openai_key_here

# App
ENV=development
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres.rvsqggigzpemerolmtfu:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
