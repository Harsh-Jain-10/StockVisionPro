# News API (Optional – enables news sentiment features)
NEWSAPI_KEY=your_newsapi_key_here

# LLM for AI Summary (Optional – enables AI-generated insights)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# App
ENV=development
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres.rvsqggigzpemerolmtfu:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# SMTP Configuration for alert email notifications (Optional – console logging fallback in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_digit_app_password
SMTP_SENDER=StockVision Pro <your_email@gmail.com>
ADMIN_EMAIL=recipient_email@gmail.com

# Scheduler
ML_RETRAIN_INTERVAL_HOURS=24
PRICE_REFRESH_SECONDS=10

# Forecasting configuration (tune without code changes)
FORECAST_CACHE_HOURS=6
MAX_FORECAST_HORIZON=90
OPPORTUNITY_SCAN_LIMIT=100
DEFAULT_FORECAST_MODEL=random_forest
FORECAST_MIN_HISTORY_DAYS=180
